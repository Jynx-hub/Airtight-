# Pulled bulk data stays local; everything else under data/ is the shared contract.
# `data/` (the rule this replaces, from 01f4daf) swallowed the whole tree, so a new
# fixture or checklist committed nowhere and still passed tests locally.
data/real/
*.duckdb
checkpoint.json

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
.pytest_cache/

# Eval output (re-derivable; transcripts can be large)
results/

# Agent-generated episodic memory (re-derivable)
memory/episodes/*.json

# Env / secrets — but DO track the config template
.env
.env.*
!.env.example
*.key
*.pem

# macOS / editors
.DS_Store
.vscode/
.idea/
