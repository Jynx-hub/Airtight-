# All of data/ is the shared contract, including the real USPTO pull (~1.1M, public
# domain) — so the ablation runs off the same claims for everyone. Two earlier rules
# hid it: `data/` (01f4daf) swallowed the whole tree, so a new fixture or checklist
# committed nowhere and still passed tests locally; `data/real/` then kept the pull
# local, so the one input the M4 numbers depend on lived on a single laptop.
# Only re-derivable build artifacts stay ignored:
*.duckdb
checkpoint.json

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
.pytest_cache/

# Eval output (re-derivable; transcripts can be large)
results/

# Agent-generated episodic memory (re-derivable) — ** matches the <disc_id>/ subdirs record() writes
memory/episodes/**/*.json

# Records distilled from documents read at ingest. Not just re-derivable —
# these are inferred from UNTRUSTED input, and must never be committed into the
# shared tree the ablation measures.
memory/ingested/*.json

# Env / secrets — but DO track the config template
.env
.env.*
# Stray env dumps that don't match the .env naming. `Untitled` really did appear
# at the repo root holding a live UPSTO_API_KEY, untracked and unignored — one
# `git add .` from a public push. Belt and braces.
Untitled
Untitled*
*.env.txt
!.env.example
*.key
*.pem

# macOS / editors
.DS_Store
.vscode/
.idea/
