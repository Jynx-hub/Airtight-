# Copy to .env (gitignored). The operator pins the endpoint here — never the agent.
# See docs/INFERENCE-LOCAL.md.

# "stub" (default: canned replies, zero network) | "live" (real endpoint)
AIRTIGHT_MODE=stub

# dev: Person 2's Modal vLLM URL, e.g. https://<workspace>--airtight-vllm-serve.modal.run/v1
# in-sandbox: https://inference.local/v1
# fallback: NVIDIA NIM cloud base URL
AIRTIGHT_BASE_URL=

# vLLM ignores this; NIM cloud requires a real key
AIRTIGHT_API_KEY=dummy

# Served model ID. UNVERIFIED — Person 2: correct against /v1/models (inference/RUNBOOK.md)
AIRTIGHT_MODEL=nvidia/nemotron-3-nano-31b-a3b

# E1/E2 — USPTO Open Data Portal. Free key: https://data.uspto.gov (register,
# then API Management). Only data/pull_uspto.py reads it; no key, no pull.
USPTO_API_KEY=

# M3 — episodic memory. Gates the WRITE only: with it true, a draft through the
# surface or `agent.run_smoke --episodes` distils its critique into lessons that
# the next draft retrieves. Retrieval of existing episodes is unconditional. The
# M4 ablation harness passes no sink, so this flag cannot touch a judged run.
AIRTIGHT_EPISODES_ENABLED=false

# M2 — HiddenLayer guardrails bus (pip install -e ".[hl]" when enabling)
AIRTIGHT_HL_ENABLED=false
# OAuth2 client credentials from AISec Console -> API Keys (research/hiddenlayer.md §4)
HIDDENLAYER_CLIENT_ID=
HIDDENLAYER_CLIENT_SECRET=
# or a pre-minted token shortcut
HIDDENLAYER_TOKEN=
# scopes the detection ruleset (hl-project-id header)
HIDDENLAYER_PROJECT_ID=
HIDDENLAYER_ENVIRONMENT=prod-us
HIDDENLAYER_TIMEOUT_SECONDS=10
