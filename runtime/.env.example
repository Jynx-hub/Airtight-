# Airtight — Runtime (Lane A) environment
# Copy to `.env` and fill in. `.env` is git-ignored; never commit real tokens.
# This file is the operator-pinned config the WHOLE system reads. The agent must
# never choose its own model endpoint — it only ever reads INFERENCE_* from here.

# ── The one flip ──────────────────────────────────────────────────────────────
# The ONLY var you change to swap backends. Both credential sets below stay intact,
# so flipping back is the same one edit — no re-pasting keys.
#   modal  = PRIMARY, self-hosted vLLM on Modal. The judged path — earns the $500
#            vLLM bounty. Uses the INFERENCE_* values just below.
#   nim    = FALLBACK, NVIDIA's free hosted endpoint. Always warm, but HOSTED, so it
#            does NOT count toward the bounty. Needs only NVIDIA_API_KEY at the
#            bottom — its URL and model slug are constants in inference_local.py.
#   unset  = legacy: read the flat INFERENCE_* vars exactly as before F3.
INFERENCE_BACKEND=modal

# ── The one pinned inference hop (`inference.local`) ──────────────────────────
# Where every model call goes. Both HiddenLayer (Lane B) and OpenShell (Lane C)
# enforce on THIS url. These are the `modal` backend's values (and the legacy path,
# still honored when INFERENCE_BACKEND is unset). After `bash modal-deploy.sh`,
# REPLACE the whole value below with the URL Modal prints (append /v1). It becomes
# https://inference.local/v1 once the OpenShell gateway lands (F5).
# NOTE: this file is sourced by bash — no angle brackets or spaces in values.
INFERENCE_BASE_URL=https://REPLACE-AFTER-DEPLOY--airtight-nemotron-serve.modal.run/v1
# Backend-agnostic alias (matches serve `--served-model-name`). The client never
# needs to know whether Nano or Super is behind it — that's the operator's choice.
INFERENCE_MODEL=nemotron
# vLLM accepts any bearer unless you set `--api-key`; keep this matched to it.
INFERENCE_API_KEY=airtight-local

# ── Modal (PRIMARY host — free tier, keeps the $500 vLLM bounty) ──────────────
# HuggingFace token to pull the GATED Nemotron weights on the Modal box. Accept the
# NVIDIA Open Model License on the HF model page first, then store it as a Modal
# Secret (NOT read from this file by Modal):  modal secret create huggingface HF_TOKEN=hf_xxx
HF_TOKEN=
# GPU/precision profile for modal_app.py. Default l40s-fp8 = cheapest fit for Nano.
#   l40s-fp8   → L40S 48GB, Nemotron 3 Nano FP8   (default — cheapest, ~$1.95/hr metered)
#   a100-bf16  → A100 80GB, Nemotron 3 Nano BF16  (quality path; one env flip)
MODAL_GPU_PROFILE=l40s-fp8
# 0 = scale to zero (dev, effectively free). Set 1 to pin a warm replica for the demo.
MODAL_MIN_CONTAINERS=0

# ── NVIDIA NIM (FALLBACK / free dev endpoint — hosted, one-flip swap) ─────────
# To fall back:  INFERENCE_BACKEND=nim   ← that is the whole flip.
# The NIM base URL and model slug are public constants baked into inference_local.py,
# so only the key lives here. Your Modal values above are untouched by the flip; going
# back is INFERENCE_BACKEND=modal. Prove it end-to-end with `bash serve-nim.sh`.
# Free `nvapi-...` key from https://build.nvidia.com ("Get API Key", no card).
# Override the constants only if NVIDIA moves the endpoint:
#   NIM_BASE_URL=https://integrate.api.nvidia.com/v1
#   NIM_MODEL=nvidia/nemotron-3-nano-30b-a3b
NVIDIA_API_KEY=
